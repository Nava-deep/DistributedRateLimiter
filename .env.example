PROJECT_NAME=distributed-rate-limiter
ENVIRONMENT=development
APP_INSTANCE_NAME=api-1
HOST=0.0.0.0
PORT=8000
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/distributed_rate_limiter
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=1.0
ADMIN_TOKEN=super-secret-admin-token
POLICY_CACHE_TTL_SECONDS=30
LOCAL_POLICY_CACHE_TTL_SECONDS=15
POLICY_REFRESH_CHANNEL=distributed-rate-limiter.policy-refresh
STRICT_STARTUP_CHECKS=false
ENABLE_POLICY_PUBSUB=true
ENABLE_LOCAL_FALLBACK_LIMITER=true
LOCAL_FALLBACK_STATE_TTL_SECONDS=120
REDIS_RETRY_ATTEMPTS=1
REDIS_RETRY_BACKOFF_MS=25
REQUEST_TIMEOUT_SECONDS=1.0
LOG_LEVEL=INFO
